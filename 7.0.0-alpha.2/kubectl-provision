#
# validate_hex_32 checks if the input is a valid 32-character hexadecimal string
#
# Example usage:
#
# validate_hex_32 "$nonce" && echo "Valid" || echo "Invalid"
#

function validate_hex_32() {
    # Check if argument exists
    if [ $# -ne 1 ]; then
        echo "Error: Exactly one argument required" >&2
        return 1
    fi
    
    # Store input
    local input="$1"
    
    # Check length
    if [ ${#input} -ne 32 ]; then
        echo "Error: Input must be exactly 32 characters long" >&2
        return 1
    fi
    
    # Check if all characters are valid hex digits
    case $input in
        *[!0-9a-fA-F]*)
            echo "Error: Input contains non-hexadecimal characters" >&2
            return 1
            ;;
    esac
    
    # If we reach here, input is valid
    return 0
}

#
# generate_random_hex_32 generates a random 32-character hexadecimal string
#
# Example usage:
#
# random_hex=$(generate_random_hex_32)
# echo "$random_hex"
#
# Verify length
# echo "Length: ${#random_hex}"
#

generate_random_hex_32() {
    chars=({0..9} {a..f})
    hex=""
    for i in {1..32}; do
        rand=$((RANDOM % 16))
        hex+="${chars[$rand]}"
    done
    echo "$hex"
}

