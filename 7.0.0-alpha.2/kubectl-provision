# check_tolerations goes over all taints and tolerations, checking if all taints are tolerated
# by the given tolerations. The operator is also respected according to the following rules:
#   - A toleration "matches" a taint if the keys are the same and the effects are the same, and:
#   - The operator is Exists (in which case no value should be specified), or
#   - The operator is Equal and the values should be equal.
check_tolerations() {
    local taints_json="$1"
    local tolerations_json="$2"

    # we can not iterate over null, so we transform null values into iterables
    if [[ "$taints_json" == "null" ]]; then
        taints_json="[]"
    fi
    if [[ "$tolerations_json" == "null" ]]; then
        tolerations_json="[]"
    fi

    jq -e --argjson taints "$taints_json" --argjson tolerations "$tolerations_json" '
        all($taints[];
        . as $taint |
        any($tolerations[];
            (.key == $taint.key) and
            (
            (.effect == null) or (.effect == $taint.effect)
            ) and
            (
            (.operator == "Exists") or
            (.operator == null and .value == $taint.value) or
            (.operator == "Equal" and .value == $taint.value)
            )
        )
        )
    ' <<< '{}'
}

function get_schedulable_nodes_considering_tolerations {
    local tolerations="$1"

    local schedulable_nodes=$(kubectl get nodes --field-selector spec.unschedulable=false -o name)
    local num_of_schedulable=0
    for node in $schedulable_nodes; do
        local node_taints=$(kubectl get $node -o json  | jq '.spec.taints')
        # sgx capable nodes and tolerated by cas bc spec
        if kubectl get --show-labels $node | grep -e "sgx.intel.com/capable=true" >> /dev/null \
            && check_tolerations "$node_taints" "$tolerations" >> /dev/null; then
            num_of_schedulable=$(( num_of_schedulable + 1 ))
        fi
    done

    echo $num_of_schedulable
}

