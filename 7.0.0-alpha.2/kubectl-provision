            export K_SGX_TOLERATIONS="$2"
            if [ ! -n "${K_SGX_TOLERATIONS}" ]; then
                usage
                error_exit "Error: Please specify a valid SGX_TOLERATIONS ('$K_SGX_TOLERATIONS' is invalid)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        ${print_version_flag})
            echo $K_PROVISION_VERSION
            exit 0
            ;;
        ${is_provisioned_flag})
            is_provisioned=1
            shift # past argument
            ;;
        ${verify_flag})
            do_verify=1
            shift # past argument
            ;;
        ${print_caskeys_flag})
            print_caskeys=1
            shift # past argument
            ;;
        ${wait_for_healthy_flag})
            do_wait_for_healthy=1
            shift # past argument
            ;;
        ${force_flag})
            use_force=1
            shift # past argument
            ;;
        ${image_flag})
            image_overwrite="$2"
            if [ ! -n "${image_overwrite}" ]; then
                usage
                error_exit "Error: Please specify a valid IMAGE ('$image_overwrite' is invalid)."
            fi
            warning "The signature of image $image_overwrite will not be verified."
            shift # past argument
            shift || true # past value
            ;;
        ${upgrade_sconecli_mrenclave_flag})
            TARGET_SCONE_CLI_MRENCLAVE="$2"
            if [ ! -n "${TARGET_SCONE_CLI_MRENCLAVE}" ]; then
                usage
                error_exit "Error: Please specify a valid mrenclave for the upgraded CAS' sconecli image ('$TARGET_SCONE_CLI_MRENCLAVE' is invalid)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        ${current_sconecli_mrenclave_flag})
            CURRENT_SCONE_CLI_MRENCLAVE="$2"
            if [ ! -n "${CURRENT_SCONE_CLI_MRENCLAVE}" ]; then
                usage
                error_exit "Error: Please specify a valid mrenclave for the CAS' current sconecli image ('$CURRENT_SCONE_CLI_MRENCLAVE' is invalid)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        ${governance_attestation_policy_flag})
            governance_attestation_policy="$2"
            if [ ! -n "${governance_attestation_policy}" ]; then
                usage
                error_exit "Error: Please specify a valid governance attestation policy ('$governance_attestation_policy' is invalid)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        ${upgrade_with_governance_flag})
            if [[ "${SVC}" == "cas" ]] ; then
                cas_upgrade_version="$2"
                do_cas_upgrade_with_governance=1
                # we cannot run docker in a kubernetes pod
                do_docker=0
                no_port_forward=1
                # checking the signatures requires docker, so we have to refrain from doing this, since we are running in a kubernetes pod.
                do_check_image_signatures=0
                if [ ! -n "${cas_upgrade_version}" ]; then
                    usage
                    error_exit "Error: Please specify a valid new VERSION for CAS when upgrading ('$cas_upgrade_version' is invalid)."
                fi
                if [[ $cas_upgrade_version =~ ^"5." ]]; then
                    error_exit "Versions prior to 6.0.0 are no longer supported. We recommend version 6.0.3 or later."
                fi
            else
                usage
                error_exit "Error: Cannot upgrade service \"$SVC\" with governance support. Expected: 'cas'"
            fi
            shift # past argument
            shift || true # past value
            ;;
        ${upgrade_flag})
            if [[ "${SVC}" == "cas" ]] ; then
                cas_upgrade_version="$2"
                do_cas_upgrade=1
                if [ ! -n "${cas_upgrade_version}" ]; then
                    usage
                    error_exit "Error: Please specify a valid new VERSION for CAS when upgrading ('$cas_upgrade_version' is invalid)."
                fi
                if [[ $cas_upgrade_version =~ ^"5." ]]; then
                    error_exit "Versions prior to 6.0.0 are no longer supported. We recommend version 6.0.3 or later."
                fi
            else
                usage
                error_exit "Error: Cannot upgrade service \"$SVC\". Expected 'cas'."
            fi
            shift # past argument
            shift || true # past value
            ;;
        ${verify_sign_key_flag})
            export cosign_public_key_file="$2"
            if [ ! -e "${cosign_public_key_file}" ]; then
                usage
                error_exit "Error: Please specify a valid public key file for image signature verfication ('$cosign_public_key_file' does not exist)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        $local_backup)
            do_backup=1;
            shift || true # past value
            ;;
        $no_image_signature_check_flag)
            do_check_image_signatures=0;
            shift || true # past value
            ;;
        $no_provisioning)
            do_preprovision=1;
            shift || true # past value
            ;;
        $post_provisioning_flag)
            do_postprovision=1;
            shift || true # past value
            ;;
        $no_docker_flag)
            do_docker=0;
            shift || true # past value
            ;;
        $force_execution_with_different_sconecli_version_flag)
            force_execution_with_different_sconecli_version=1;
            shift || true # past value
            ;;
        $no_port_forward_flag)
            no_port_forward=1;
            shift || true # past value
            ;;            
        $scone_cas_addr_flag)
            scone_cas_addr=$2;
            if [[ "${scone_cas_addr}" == "" ]]; then
                usage
                error_exit "Error: Please specify a valid SCONE_CAS_ADDR ('$scone_cas_addr' is not valid)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        $cas_client_port_flag)
            CAS_CLIENT_PORT=$2;
            if [[ "${CAS_CLIENT_PORT}" == "" ]]; then
                usage
                error_exit "Error: Please specify a valid CAS_CLIENT_PORT ('$CAS_CLIENT_PORT' is not valid)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        $local_cas_client_port_flag)
            LOCAL_CAS_CLIENT_PORT=$2;
            if [[ "${LOCAL_CAS_CLIENT_PORT}" == "" ]]; then
                usage
                error_exit "Error: Please specify a valid LOCAL_CAS_CLIENT_PORT ('$LOCAL_CAS_CLIENT_PORT' is not valid)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        $post_provisioning_owner_identity_flag)
            post_provisioning_owner_identity=$2;
            if [ ! -e "${post_provisioning_owner_identity}" ]; then
                usage
                error_exit "Error: Please specify a valid owner-identity file ('$post_provisioning_owner_identity' does not exist)."
            fi
            shift # past argument
            shift || true # past value
            ;;
        $help_flag)
            do_help=1
            shift
            ;;
        *)
            if [[ $1 == -* ]] ; then
                usage
                warning "Arguments passed: $args"
                error_exit "Error: Unknown argument passed: $1";
            elif [[ "${SVC}" == "" ]]; then
                SVC="$1"
            elif [[ "${NAME}" == "" ]]; then
                NAME="$1"
                if [[ "${#NAME}" -gt 15  && "$SVC" == "cas" ]]; then
                    usage
                    warning "Arguments passed: $args"
                    error_exit "Error: Name of the cas must not be longer than 15 characters"
                fi
            else
                usage
                warning "Arguments passed: $args"
                error_exit "Error: Unknown parameter passed: $1";
            fi
            shift # past argument
            ;;
    esac
done

set_defaults

if [ $do_help != 0 ] ; then
    usage
    exit 0
fi

if [[ "${SVC}" != "cas" ]]; then
    usage
    error_exit "Error: Please specify a valid SVC ('$SVC' is invalid)."
fi

if [[ $NO_BACKUP -eq 1 && $do_wait_for_healthy == 1 ]]; then
    error_exit "We do not support the simultaneous use of $no_backup_flag and $wait_for_healthy_flag"
fi

if [[ "$NAME" == "" ]] ; then
    verbose "No service NAME specified - using '$SVC' as NAME"
    NAME="$SVC"
fi

if [[ $use_force == 1 ]]; then
    if [[ $do_cas_upgrade_with_governance == 0 && $do_cas_upgrade == 0 ]]; then
        error_exit "We only support $force_flag together with the following flags: $upgrade_flag, $upgrade_with_governance_flag"
    fi
fi

if [[ $do_cas_upgrade_with_governance == 1 ]] ; then
    if [[ $do_cas_upgrade == 1 ]]; then
        error_exit "The $upgrade_with_governance_flag and the $upgrade_flag flags are mutually exclusive."
    fi

    if [[ "$TARGET_SCONE_CLI_MRENCLAVE" == "" ]]; then
        error_exit "Please use $upgrade_sconecli_mrenclave_flag to specify the mrenclave of the target sconecli image."
    fi
else
    if [[ "$governance_attestation_policy" != "" ]]; then
        error_exit "The $governance_attestation_policy_flag flag requires the $upgrade_with_governance_flag flag."
    fi
fi

if [[ "$do_cas_upgrade" == 1 ]]; then
    if [[ "$CURRENT_SCONE_CLI_MRENCLAVE" == "" || "$TARGET_SCONE_CLI_MRENCLAVE" == "" ]]; then
        if [[ "$do_docker" == 0 ]]; then
            error_exit "When the use of docker is disabled, we cannot determine the mrenclaves required for upgrading the CAS. Please use both $upgrade_sconecli_mrenclave_flag and $current_sconecli_mrenclave_flag to specifiy the required mrenclaves, or enable the use of docker by removing the $no_docker_flag flag."
        fi
    fi
fi

if [[ "$TARGET_SCONE_CLI_MRENCLAVE" != "" && "$do_cas_upgrade" != 1 && "$do_cas_upgrade_with_governance" != 1  ]]; then
    error_exit "The use of $upgrade_sconecli_mrenclave_flag only makes sense when upgrading, i.e., together with either of the $cas_upgrade_flag or $cas_upgrade_with_governance_flag flags. When not upgrading, please use $current_sconecli_mrenclave_flag to specify the mrenclave of the CAS's sconecli image."
fi

if [[ "$do_postprovision" == 1 && "$do_docker" == 0 && "$CURRENT_SCONE_CLI_MRENCLAVE" == "" ]]; then
    error_exit "When the use of docker is disabled, we cannot determine the mrenclave required for post-provisioning. Please use $current_sconecli_mrenclave_flag to specifiy the required mrenclave, or enable the use of docker by removing the $no_docker_flag flag."
fi

if [[ "$CURRENT_SCONE_CLI_MRENCLAVE" == "" ]]; then
    if [[ "$do_docker" == 0 ]]; then
        if [[ "$do_cas_upgrade_with_governance" == 1
                    || "$is_provisioned" == 1
                    || "$print_caskeys" == 1
                    || "$do_backup" == 1
                    || "$do_verify" == 1
                    || "$do_preprovision" == 1
                    || "$do_recovery" == 1 ]]; then
            # The above is a list of all the operations that do not require CURRENT_SCONE_CLI_MRENCLAVE, so we allow it to be empty in these cases.
            warning "When the use of docker is disabled, we cannot determine the mrenclave of the CAS's sconecli image. This is required for some - but not all - operations on the CAS. Please use $current_sconecli_mrenclave_flag to specifiy the required mrenclave if needed, or enable the use of docker by removing the $no_docker_flag flag."
        else
            # We do not know for a fact that the operation does require CURRENT_SCONE_CLI_MRENCLAVE, but we still error out. Maybe not the best option?
            error_exit "When the use of docker is disabled, we cannot determine the mrenclave of the CAS's sconecli image. Please use the $current_sconecli_mrenclave_flag flag to specifiy the required mrenclave, or enable the use of docker by removing the $no_docker_flag flag."
        fi
    fi
fi

if [[ $do_postprovision == 0 && "$post_provisioning_owner_identity" != "" ]] ; then
    error_exit "The $post_provisioning_owner_identity_flag flag requires the $post_provisioning_flag flag"
fi

if [[ $do_postprovision == 1 && $do_preprovision == 1 ]]; then
    error_exit "The $post_provisioning_flag flag is not allowed together with the $no_provisioning flag."
fi

if [ $do_docker == 0 ]
then
    if ! command -v scone >/dev/null 2>&1; then
        error_exit "The $no_docker_flag flag requires the scone CLI, but it is not installed."
    fi

    if ! scone --version >/dev/null 2>&1; then
        error_exit "The $no_docker_flag flag requires the scone CLI, but it is working properly."
    fi

    if [ $do_cas_upgrade == 1 ]; then 
        CAS_VERSION=$cas_upgrade_version
    else
        CAS_VERSION=$VERSION
    fi

    SCONE_CLI_VERSION_FULL="$(scone --version)"
    SCONE_CLI_VERSION=$(echo "$SCONE_CLI_VERSION_FULL" | grep -oE '\S*[0-9]\S*')
    SCONE_CLI_MAJOR="${SCONE_CLI_VERSION%%.*}"
    VERSION_MAJOR="${CAS_VERSION%%.*}"

    if [ "$SCONE_CLI_MAJOR" != "$VERSION_MAJOR" ]; then
        if [ "$force_execution_with_different_sconecli_version" == 1 ]; then
            warning "Using CLI version ($SCONE_CLI_VERSION) and CAS version ($CAS_VERSION). This may cause issues."
        else
            error_exit "Using CLI version ($SCONE_CLI_VERSION) and CAS version ($CAS_VERSION). This may cause issues. Use $force_execution_with_different_sconecli_version_flag to force the use."
        fi
    elif [ "$SCONE_CLI_VERSION" != "$CAS_VERSION" ]; then
            warning "SCONE CLI version ($SCONE_CLI_VERSION) does not match CAS version ($CAS_VERSION). This may cause issues."
    fi
fi

if ! kubectl get namespace "$NAMESPACE" > /dev/null 2>/dev/null
then
    error_exit "Namespace '$NAMESPACE' cannot be retrieved. Either it does not exist or the cluster is not reachable."
fi

export SERVICE_PID_FILE="$TARGET_DIR/.forward-pid"

# set all needed image env vars
export SCONECLI_IMAGE="${IMAGE_REPO}/${IMAGE_PREFIX}sconecli:${VERSION}"
export CAS_IMAGE="${IMAGE_REPO}/${IMAGE_PREFIX}cas:${VERSION}"
export BACKUP_CONTROLLER_IMAGE="${IMAGE_REPO}/${IMAGE_PREFIX}backup-controller:${VERSION}"
export CAS_RECOVERY_IMAGE="$IMAGE_REPO/${IMAGE_PREFIX}cas-recovery:$VERSION"
if [[ $do_cas_upgrade == 1 || $do_cas_upgrade_with_governance == 1 ]]; then
    export BACKUP_CONTROLLER_UPGRADE_IMAGE="${IMAGE_REPO}/${IMAGE_PREFIX}backup-controller:${cas_upgrade_version}"
    export CAS_UPGRADE_IMAGE="${IMAGE_REPO}/${IMAGE_PREFIX}cas:${cas_upgrade_version}"
    export CAS_SAFETY_SERVICE_UPGRADE_IMAGE="${IMAGE_REPO}/${IMAGE_PREFIX}cas-safety-service:${cas_upgrade_version}"
fi

# Calculating the sconecli mrenclaves
if [[ "$TARGET_SCONE_CLI_MRENCLAVE" == "" && "$do_cas_upgrade" == 1 ]]; then
    export TARGET_SCONE_CLI_MRENCLAVE="$(docker run --platform linux/amd64 --pull always --rm --entrypoint scone -e SCONE_HASH=1 "$BACKUP_CONTROLLER_UPGRADE_IMAGE" cas | tr -d '\r')"
fi
if [[ "$CURRENT_SCONE_CLI_MRENCLAVE" == "" && "$do_docker" == 1 ]]; then
    export CURRENT_SCONE_CLI_MRENCLAVE="$(docker run --platform linux/amd64 --pull always --rm --entrypoint scone -e SCONE_HASH=1 "$BACKUP_CONTROLLER_IMAGE" cas | tr -d '\r')"
fi
# NOTE: at this point, CURRENT_SCONE_CLI_MRENCLAVE might still be empty.
if [[ "$CURRENT_SCONE_CLI_MRENCLAVE" == "" ]]; then
    warning "Continuing without a value for the mrenclave of the CAS' sconecli image."
fi

verbose "Checking if CAS '$NAME' in namespace '$NAMESPACE' already exists"
export IMAGE=""
EXISTS=1  JSON=$(kubectl get cas "$NAME" --namespace "$NAMESPACE" -o json 2>/dev/null) || EXISTS=0

if [[ "$CAS_CLIENT_PORT" == "" ]]; then
    if [[ $EXISTS == 1 ]] ; then
        CAS_CLIENT_PORT=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.spec.service.clientPort}')
        verbose "Using the client port of the existing CAS. CAS_CLIENT_PORT: $CAS_CLIENT_PORT"
    else
        CAS_CLIENT_PORT=$DEFAULT_CAS_CLIENT_PORT
        verbose "Using the default CAS client port. CAS_CLIENT_PORT: $CAS_CLIENT_PORT"
    fi
else
    verbose "Using the user supplied CAS client port. CAS_CLIENT_PORT: $CAS_CLIENT_PORT"
fi

if [[ "$LOCAL_CAS_CLIENT_PORT" == "" ]]; then
    LOCAL_CAS_CLIENT_PORT=$CAS_CLIENT_PORT
    verbose "Using the the value of CAS_CLIENT_PORT as LOCAL_CAS_CLIENT_PORT. LOCAL_CAS_CLIENT_PORT: $LOCAL_CAS_CLIENT_PORT"
else
    verbose "Using the user supplied local CAS client port. LOCAL_CAS_CLIENT_PORT: $LOCAL_CAS_CLIENT_PORT"
fi

check_prerequisites
if [[ $do_docker == 1 ]]; then
    check_port_forward "$LOCAL_CAS_CLIENT_PORT"
fi
if [[ $do_check_image_signatures == 1 ]]; then
    if [[ $do_docker == 0 ]]; then
        error_exit "You have chosen the default behaviour of checking the signatures of the docker images used. This however requires docker which has been turned off ($no_docker_flag). Either remove the $no_docker_flag flag or use the $no_image_signature_check_flag flag additionally."
    fi
    check_image_signatures
else
    warning "Skipping checking image signatures"
fi

if [[ $do_backup == 1 ]] ; then
    if ! check_if_provisioned > /dev/null; then
        error_exit "CAS $NAME in namespace $NAMESPACE is not provisioned: refusing to backup an unprovisioned CAS"
    fi

    SNAP_DIR="cas-database-snapshots/$NAME-$NAMESPACE-last-snapshot-db"
    POD="$NAME-0"
    mkdir -p cas-database-snapshots
    mv -f "$SNAP_DIR" "$SNAP_DIR.bak" 2> /dev/null || true
    verbose "Creating backup of CAS $NAME in namespace $NAMESPACE in $SNAP_DIR"

    kubectl cp $POD:/var/mnt/cas-database-snapshots/last-completed "$SNAP_DIR" -n $NAMESPACE --retries=20 || error_exit "Backup of latest snapshot of CAS $NAME in namespace $NAMESPACE in $SNAP_DIR failed."
    verbose "Done"
    exit 0
fi

if [ $is_provisioned == 1 ]
then
    check_if_provisioned
    exit $? # Only executed when check_if_provisioned returns 0. rc 1 causes earlier exit due to set -e.
fi

if [ $print_caskeys == 1 ]
then
    print_cas_keys
    exit 0
fi

# If we are upgrading:
if [[ $do_cas_upgrade == 1 || $do_cas_upgrade_with_governance == 1 ]]; then
    if [[ "$SVC" != "cas" ]] ; then
        error_exit "Only CAS upgrade is supported: $SVC is not supported"
    fi
    if [[ "$VERSION" == "$cas_upgrade_version" ]] ; then
        error_exit "CAS upgrade would not change the version: requested version is $cas_upgrade_version (existing is $VERSION)"
    fi

    JSON=$(kubectl get cas "$NAME" --namespace "$NAMESPACE" -o json 2>/dev/null) || error_exit "Cannot find CAS $NAME in namespace $NAMESPACE. Exiting!"

    # We can only safetly upgrade to new version when .spec.tolerations is equals to .spec.backup-controller.tolerations
    # to ensure we can register the all nodes that CAS pod can move to. We sort by key to we can compare afterwords.
    cas_tolerations=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq -r '.spec.tolerations')
    cas_bc_tolerations=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq -r '.spec."backup-controller".tolerations')
    if [[ "$cas_tolerations" != "null" ]]; then
        cas_tolerations=$(echo $cas_tolerations | jq '.spec.tolerations | sort_by(.key)')
    fi
    if [[ "$cas_bc_tolerations" != "null" ]]; then
        cas_bc_tolerations=$(echo $cas_bc_tolerations | jq '.spec."backup-controller".tolerations | sort_by(.key)')
    fi
    if [[ "$cas_tolerations" != "$cas_bc_tolerations" ]]; then
        warning "CAS tolerations and its backup-controller tolerations differ (.spec.tolerations and .spec.backup-controller.tolerations)"
        warning "Current .spec.tolerations:"
        warning "$cas_tolerations"
        warning "Current .spec.backup-controller.tolerations:"
        warning "$cas_bc_tolerations"
        error_exit "Unable to continue with upgrade! Set the same tolerations for both to be able to continue."
    fi

    export IMAGE=$(echo $JSON | jq '(.spec.image)' | tr -d '"' | jq -R '. | sub( "(?<image>[^':']*):(?<tag>.*)" ; "\(.image)")' | tr -d '"' )
    TAG=$(echo $JSON | jq '(.spec.image)' | tr -d '"' | jq -R '. |   sub( "(?<image>[^':']*):(?<tag>.*)" ; "\(.tag)")' | tr -d '"' )
    if [[ "$IMAGE" == "null" || "$IMAGE" == "" ]] ; then
        error_exit "Cannot determine image name of CAS '$NAME' in namespace '$NAMESPACE'"
    fi

    verbose "Current CAS image '$IMAGE' has tag '$TAG'"
    IMAGE="$IMAGE:$TAG"
    if [[ "$VERSION" != "$TAG" ]] ; then
        if [[ $use_force == 0 ]]; then
            error_exit "Expected CAS of version $VERSION but found image of version $TAG. Please set the correct expected version. Exiting."
        fi
        warning "Performing forced upgrade of cas $NAME in namespace $NAMESPACE. Continuing although its image has the version $TAG instead of the expected $VERSION."
    fi

    if [[ "$image_overwrite" != "" ]] ; then
        error_exit "We only support CAS upgrade for expected image versions. Exiting!"
    fi

    EXPECTED_IMAGE="$CAS_IMAGE"
    NEXT_IMAGE="$CAS_UPGRADE_IMAGE"

    if [[ "$IMAGE" != "$EXPECTED_IMAGE" ]] ; then
        if [[ "$IMAGE" == "$CAS_RECOVERY_IMAGE" ]] ; then
            warning "CAS runs recovery image: $CAS_RECOVERY_IMAGE"
            export EXPECTED_IMAGE="$CAS_RECOVERY_IMAGE"
        else
            if [[ $use_force == 0 ]]; then
                error_exit "Expected CAS Image '$EXPECTED_IMAGE' but retrieved  '$IMAGE'. We only support CAS upgrade for expected image versions, unless $force_flag is used - exiting! "
            fi
            warning "Performing forced upgrade of cas $NAME in namespace $NAMESPACE. Continuing although its current image is not the expected. Current: $IMAGE. Expected: $EXPECTED_IMAGE."
        fi
    fi

    verbose "Checking if CAS is healthy"

    STATE=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.status.state}')

    if [[ "$STATE" != "HEALTHY" ]] ; then
        if [[ $use_force == 0 ]]; then
            error_exit "State of CAS '$NAME' in namespace '$NAMESPACE' is '$STATE': Expected HEALTHY state. Exiting!"
        fi
        warning "Performing forced upgrade of cas $NAME in namespace $NAMESPACE. Continuing although its state is $STATE as opposed to HEALTHY"
    fi

    export SVCNAME=`kubectl get svc --namespace "$NAMESPACE" --selector "app.kubernetes.io/instance=$NAME,app.kubernetes.io/name=cas" | tail -1 | awk '{ print $1 }'`
    verbose "CAS $NAME has service name $SVCNAME"

    if [[ "$SVCNAME" == "" ]] ; then
      error_exit "Failed to determine the service name of CAS $NAME in namespace $NAMESPACE"
    fi

    verbose "Checking if CAS needs upgrading"


    warning "Upgrading CAS version $VERSION to version $cas_upgrade_version"

    # todo: use a local path for the policy name
    backup_controller_session_spec=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.spec.backup-controller.session}')
    if [[ "$backup_controller_session_spec" == "" ]] ; then
        error_exit "Was not able to find the .spec.backup-controller.session for CAS $NAME in namespace $NAMESPACE. CAS upgrade requires to activate primary/backup first. Is primary/backup really activated for this CAS?"
    fi

    POLICY_NAME=$(echo "$backup_controller_session_spec" | sed 's/\/register$//')  # removing "/register" if present
    POLICY_NAME=$(echo "$POLICY_NAME" | sed 's/\/upgrade$//')  # removing "/upgrade" if present

    if [[ "$backup_controller_session_spec" == */register ]]; then
        updated_backup_controller_session_spec="${backup_controller_session_spec%/register}/upgrade"
        verbose 'Updating CAS .spec.backup-controller.session, switching from /register to /upgrade'
        kubectl patch cas $NAME -n $NAMESPACE --type='json' --patch """
        [
            {
                "op": "replace",
                "path": "/spec/backup-controller/session",
                "value": $updated_backup_controller_session_spec
            },
        ]""" || {
            error_exit "Unable to update CAS .spec.backup-controller.session from $backup_controller_session_spec to $updated_backup_controller_session_spec"
        }
    fi

    if [[ $do_cas_upgrade_with_governance == 1 ]]; then
        if [[ "$governance_attestation_policy" == "" ]]; then
            # In the $do_cas_upgrade case, POLICY_NAME is the policy that should contain the new MrEnclave.
            # However, in the $do_cas_upgrade_with_governance case, and no attestation policy name was
            # provided, we assume the policy containing the new MrEnclave is the attestation policy of
            # the root namespace of POLICY_NAME (if it isn't the root namespace itself).
            # This means, if POLICY_NAME is cas-owner/primary-backup,
            # we assume the new MrEnclave is present in cas-owner/attestation-policy.
            cas_policy_namespace="${POLICY_NAME%%/*}"
            POLICY_NAME="$cas_policy_namespace/attestation-policy"
        else
            POLICY_NAME="$governance_attestation_policy"
        fi
    fi

    verbose "Policy name for CAS $NAME in namespace $NAMESPACE: $POLICY_NAME"

    if [[ "$do_cas_upgrade" == 1 ]]; then

        verbose "Updating MrEnclave from  $CURRENT_SCONE_CLI_MRENCLAVE (version $VERSION) to $TARGET_SCONE_CLI_MRENCLAVE (version $cas_upgrade_version)"

        if [[ "$CURRENT_SCONE_CLI_MRENCLAVE" == "$TARGET_SCONE_CLI_MRENCLAVE" ]] ; then
            warning "MrEnclave of backup controller has not changed - no need to upgrade policy."
        else
            verbose "Upgrading Backup Policy $POLICY_NAME"

            if [ $no_port_forward == 1 ]; then
                cas_addr="$NAME.$NAMESPACE.svc"
            else
                verbose "Enabling Port-Forwarding to $NAME in namespace $NAMESPACE"
                check_port_forward "$LOCAL_CAS_CLIENT_PORT"
                cas_svc_port_forward
                cas_addr="localhost"
            fi
            verbose "Reading Session $POLICY_NAME from CAS $NAME in namespace $NAMESPACE"

            if [ $do_docker == 1 ]
            then
                touch "${TARGET_MOUNT_DIR}/identity/config.json" || error_exit "It seems you are not the owner of file '${TARGET_MOUNT_DIR}/identity/config.json' - please change owner of this file"

                docker pull ${SCONECLI_IMAGE} >/dev/null
                docker run --rm --platform linux/amd64  \
                    --add-host=host.docker.internal:host-gateway --network host \
                    --user $(id -u):$(id -g) \
                    -v "$TARGET_MOUNT_DIR"/identity:/identity \
                    -e SCONE_CLI_CONFIG="/identity/config.json" \
                    -e LOCAL_CAS_CLIENT_PORT="$LOCAL_CAS_CLIENT_PORT" \
                    -e SGX_TOLERATIONS="$SGX_TOLERATIONS" \
                    -e SGX_STD_TOLERATIONS="$SGX_STD_TOLERATIONS" \
                    -e SCONE_NO_TIME_THREAD=1 \
                    -e POLICY_NAME="$POLICY_NAME" \
                    -e CURRENT_SCONE_CLI_MRENCLAVE="$CURRENT_SCONE_CLI_MRENCLAVE" \
                    -e TARGET_SCONE_CLI_MRENCLAVE="$TARGET_SCONE_CLI_MRENCLAVE" \
                    -e SCONE_PRODUCTION=0 \
                    -e SCONE_MODE="sim" \
                    -e NAME="$NAME" \
                    ${SCONECLI_IMAGE} \
                    sh -c 'set -e ; scone cas attest $SGX_TOLERATIONS host.docker.internal:$LOCAL_CAS_CLIENT_PORT || scone cas attest $SGX_STD_TOLERATIONS host.docker.internal:$LOCAL_CAS_CLIENT_PORT || { echo ERROR: Attestation of CAS $NAME failed - exiting ; exit 1; } ; scone cas set-default host.docker.internal:$LOCAL_CAS_CLIENT_PORT  ;   scone session read $POLICY_NAME > /identity/session.tmp ;  HASH=`scone session verify /identity/session.tmp` ; echo HASH=$HASH ; sed -i "s/^predecessor: .*\$/predecessor: ${HASH}/g" /identity/session.tmp ; sed -i "s/${CURRENT_SCONE_CLI_MRENCLAVE}/${TARGET_SCONE_CLI_MRENCLAVE}/g" /identity/session.tmp ; scone session update /identity/session.tmp'

                chmod og-rwx "${TARGET_MOUNT_DIR}/identity/config.json"
            else
                export SCONE_CLI_CONFIG="$TARGET_DIR/identity/config.json"
                export SCONE_LOG="ERROR"
                export SCONE_NO_TIME_THREAD=1
                export SCONE_PRODUCTION=0
                export SCONE_MODE="sim"

                scone cas attest $SGX_TOLERATIONS $cas_addr > /dev/null \
                || scone cas attest $SGX_STD_TOLERATIONS $cas_addr > /dev/null \
                || { echo "ERROR: Attestation of CAS $cas_addr failed - exiting" ; exit 1; }

                scone cas set-default $cas_addr
                scone session read "$POLICY_NAME" > $TARGET_DIR/identity/session.tmp

                HASH=`scone session verify $TARGET_DIR/identity/session.tmp`
                echo HASH=$HASH
                sed -i "s/^predecessor: .*\$/predecessor: ${HASH}/g" $TARGET_DIR/identity/session.tmp
                sed -i "s/${CURRENT_SCONE_CLI_MRENCLAVE}/${TARGET_SCONE_CLI_MRENCLAVE}/g" $TARGET_DIR/identity/session.tmp

                scone session update $TARGET_DIR/identity/session.tmp
            fi

            if [[ $SERVICE_PID != 0 ]] ; then
                verbose "Shutting down port-forwarding"
                kill $SERVICE_PID
            fi
        fi
    else  # [[ "$do_cas_upgrade_with_governance" == 1 ]]; then
        verbose "Governance: Enabling Port-Forwarding to $NAME in namespace $NAMESPACE"
        if [ $no_port_forward == 1 ]; then
            cas_addr="$NAME.$NAMESPACE:$LOCAL_CAS_CLIENT_PORT"
        else
            check_port_forward "$LOCAL_CAS_CLIENT_PORT"
            cas_svc_port_forward
            cas_addr="localhost:$LOCAL_CAS_CLIENT_PORT"
        fi

        verbose "Governance: Double-checking that the new MrEnclave ($TARGET_SCONE_CLI_MRENCLAVE) of the backup controller image indeed is included in the $POLICY_NAME policy."
        verbose "Governance: Upgrading Backup Policy $POLICY_NAME"

        verbose "Governance: Reading Session $POLICY_NAME from CAS $NAME in namespace $NAMESPACE"

        export SCONE_CLI_CONFIG="$TARGET_DIR/identity/config.json"
        export SCONE_NO_TIME_THREAD=1
        export SCONE_PRODUCTION=0
        export SCONE_MODE="sim"

        scone cas attest $SGX_TOLERATIONS $cas_addr > /dev/null \
        || scone cas attest $SGX_STD_TOLERATIONS $cas_addr > /dev/null \
        || error_exit "Attestation of CAS $cas_addr failed - exiting"

        scone cas set-default $cas_addr
        scone session read "$POLICY_NAME" > $TARGET_DIR/identity/session.tmp

        new_mrenclave_present=true
        cat $TARGET_DIR/identity/session.tmp | grep -q $TARGET_SCONE_CLI_MRENCLAVE || new_mrenclave_present=false

        if [[ $SERVICE_PID != 0 ]] ; then
            verbose "Shutting down port-forwarding"
            kill $SERVICE_PID
        fi

        if [[ "$new_mrenclave_present" == false ]]; then
            error_exit "Failed to find the mrenclave of the new target sconecli image ($BACKUP_CONTROLLER_UPGRADE_IMAGE) in the policy $POLICY_NAME. Since the CAS was created with governance, you have to first update the attestation policy with the new mrenclave ($TARGET_SCONE_CLI_MRENCLAVE, i.e., the one specified with $upgrade_sconecli_mrenclave_flag)."
        else
            verbose "Governance: Successfully verified the presence of the mrenclave $TARGET_SCONE_CLI_MRENCLAVE in the policy $POLICY_NAME"
        fi
    fi

    export cas_manifest_for_backup_update_new="$TARGET_DIR/owner-config/cas-${NAMESPACE}-${NAME}-${cas_upgrade_version}-manifest.json"
    export cas_manifest_for_backup_update_old="$TARGET_DIR/owner-config/cas-${NAMESPACE}-${NAME}-${cas_upgrade_version}-input.json"

    verbose "Upgrading CAS custom resource with new backup controller image: \"$BACKUP_CONTROLLER_UPGRADE_IMAGE\" - will save state in '$cas_manifest_for_backup_update_new'"

    verbose "Getting current CAS custom resource manifest and writing it to '$cas_manifest_for_backup_update_old'"
    old_backup_controller_name=$(get_backup_controller_pod_name "$NAME" "$NAMESPACE")
    kubectl get cas $NAME -n $NAMESPACE -o json > "$cas_manifest_for_backup_update_old" || error_exit "failed to retrieve CAS manifest"

    jq  ".spec.\"backup-controller\".image = \"$BACKUP_CONTROLLER_UPGRADE_IMAGE\"" "$cas_manifest_for_backup_update_old"  > "$cas_manifest_for_backup_update_new"
    jq  "(.spec.\"backup-controller\".env[] | select(.name == \"BACKUP_CAS_IMAGE\").value) = \"$NEXT_IMAGE\"" "$cas_manifest_for_backup_update_new" > "$cas_manifest_for_backup_update_new.tmp"
    mv "$cas_manifest_for_backup_update_new.tmp" "$cas_manifest_for_backup_update_new" || error_exit "failed to move $cas_manifest_for_backup_update_new.tmp into $cas_manifest_for_backup_update_new"

    verbose "Updating CAS CR spec.backup-controller.image and .spec.backup-controller.env (for BACKUP_CAS_IMAGE env var) with the values from '$cas_manifest_for_backup_update_new' to update only the CAS backup controller image first!"

    verbose "Patching CAS CR to update backup controller images..."
    kubectl patch cas $NAME -n $NAMESPACE --type='json' --patch """
        [
            {
                "op": "replace",
                "path": "/spec/backup-controller/image",
                "value": $(jq ".spec.\"backup-controller\".image" $cas_manifest_for_backup_update_new)
            },
            {
                "op": "replace",
                "path": "/spec/backup-controller/env",
                "value": $(jq ".spec.\"backup-controller\".env" $cas_manifest_for_backup_update_new)
            }
        ]""" || error_exit "Failed to patch CAS CR. Check spec.backup-controller.image and .spec.backup-controller.env (for BACKUP_CAS_IMAGE env var) in '$cas_manifest_for_backup_update_new'"

    verbose "Checking if we succeed..."

    NEXT_IMAGE="$CAS_UPGRADE_IMAGE"
    IMAGE="$CAS_IMAGE"

    verbose "The new manifest of CAS $NAME in namespace $NAMESPACE is stored in $cas_manifest_for_backup_update_new"
    verbose "  - You can modify the metadata and spec fields of the manifest and apply the changes with 'kubectl apply -f \"$cas_manifest_for_backup_update_new\""

    new_backup_controller_name=$(get_backup_controller_pod_name "$NAME" "$NAMESPACE")
    while [[ "$new_backup_controller_name" == "$old_backup_controller_name" ]]; do
        sleep 1
        new_backup_controller_name=$(get_backup_controller_pod_name "$NAME" "$NAMESPACE")
        verbose "Waiting for the backup controller pod to change name - bacause image changed, pod will be replaced"
    done

    # When operator version supports it, we can check for status.phase == Upgrading
    # to be sure that the operator has seen the change and started the upgrade process.
    # This is supported since operator version "v7.x.y".
    targetUpgradingPhase="Upgrading"
    casHasUpgradingPhase=$(kubectl get crd cas.services.scone.cloud  -o json | jq -r  'any(.spec.versions[0].schema.openAPIV3Schema.properties.status.properties.phase.enum[]; . == "Upgrading")')
    if [[ "$casHasUpgradingPhase" == "true" ]]; then
        verbose 'The CAS CRD supports status.phase with Upgrading phase - will check for "Upgrading" phase during upgrade'
    else
        verbose 'The CAS CRD does not support status.phase with Upgrading phase - will check for "EnablingMigration" phase during upgrade'
        targetUpgradingPhase="EnablingMigration"
    fi

    verbose "Waiting for CAS to reach $targetUpgradingPhase phase - as expected when changing backup controller image"

    CURRENT_CAS_PHASE_IN_UPGRADE=""
    while [[ "$CURRENT_CAS_PHASE_IN_UPGRADE" != "$targetUpgradingPhase"  ]] ; do
        sleep 1
        CURRENT_CAS_PHASE_IN_UPGRADE=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.status.phase}')
        verbose "Waiting for CAS get to $targetUpgradingPhase phase - current phase is $CURRENT_CAS_PHASE_IN_UPGRADE"
    done
    verbose "CAS reached $targetUpgradingPhase phase - as expected when changing backup controller image"

    verbose "The name of the backup-controller pod has changed. Let's wait for the new one to have the expected number of registered backups."
    verbose "Checking whether there are sgx-capable nodes with taints..."
    
    actual_migration=""
    expected_migration="0/0"
    while [[ "$actual_migration" != "$expected_migration" ]]; do
        sleep 5
        num_schedulable_and_capable_nodes=$(get_schedulable_nodes_considering_tolerations "$cas_tolerations")
        expected_migration="$num_schedulable_and_capable_nodes/$num_schedulable_and_capable_nodes"
        actual_migration=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.status.migrationNodeRatio}')
        verbose "Waiting for all nodes, i.e., $expected_migration, to be registered for backup. Now: $actual_migration. This can take some minutes..."
    done
    verbose "All $expected_migration nodes are now registered for backup."

    STATE=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.status.state}')
    while [[ "$STATE" != "HEALTHY"  ]] ; do
        sleep 1
        STATE=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.status.state}')
        verbose "Waiting for CAS to become HEALTHY again - current state is $STATE"
    done

    verbose "CAS is HEALTHY again, i.e., SCONE Operator was able to register all SGX nodes as backup controllers"

    verbose "Sanity check that the images have changed as expected"
    backup_cas_image=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq  ".spec.\"backup-controller\".env[] | select(.name == \"BACKUP_CAS_IMAGE\").value")
    verbose "backup_cas_image in backup-controller.env[] (should be new version) $backup_cas_image"
    backup_image=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq  ".spec.\"backup-controller\".image")
    verbose "backup_image in backup-controller.image (should be new version) $backup_image"
    cas_image=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq  ".spec.image")
    verbose "cas_image  (should still be old version) $cas_image"

    verbose "Updating CAS image in CAS custom resource manifest"

    kubectl get cas $NAME -n $NAMESPACE -o json > "$cas_manifest_for_backup_update_old" || error_exit "failed to retrieve CAS manifest"

    # It only makes sense to change also safety service if there was safety service set already
    if jq -e '.spec.safetyService?.image?' "$cas_manifest_for_backup_update_old" > /dev/null; then
        jq -e ".spec.image = \"$NEXT_IMAGE\" | .spec.safetyService.image = \"$CAS_SAFETY_SERVICE_UPGRADE_IMAGE\"" "$cas_manifest_for_backup_update_old" > "$cas_manifest_for_backup_update_new"
        verbose "Updating CAS CR .spec.image and .spec.safetyService.image with values from '$cas_manifest_for_backup_update_new' to update only the CAS image in this phase!"
        SAFETY_SERVICE_IMAGE_UPGRADE_PATCH_FOR_CAS="""
        {
            "op": "replace",
            "path": "/spec/safetyService/image",
            "value": "$CAS_SAFETY_SERVICE_UPGRADE_IMAGE",
        },"""
    else
        jq -e ".spec.image = \"$NEXT_IMAGE\"" "$cas_manifest_for_backup_update_old" > "$cas_manifest_for_backup_update_new"
        verbose "Updating CAS CR .spec.image with values from '$cas_manifest_for_backup_update_new' to update only the CAS image in this phase!"
    fi

    kubectl patch cas $NAME -n $NAMESPACE --type='json' --patch """
        [
            $SAFETY_SERVICE_IMAGE_UPGRADE_PATCH_FOR_CAS
            {
                "op": "replace",
                "path": "/spec/image",
                "value": $(jq ".spec.image" $cas_manifest_for_backup_update_new)
            }
        ]"""  || error_exit "Failed to patch CAS CR. Check spec.image in '$cas_manifest_for_backup_update_new'"

    new_cas_image_in_pod=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq -r ".spec.image")
    verbose "Waiting for CAS to have spec.image=$NEXT_IMAGE spec applied in its pod - current is spec.image=$new_cas_image_in_pod"
    max_attempts=90
    while [[ "$new_cas_image_in_pod" != "$NEXT_IMAGE" ]]; do
        if [[ $max_attempts -eq 0 ]]; then
            error_exit "Failed: CAS spec.image=$NEXT_IMAGE spec was not applied in its pod in time!"
        fi
        sleep 10
        new_cas_image_in_pod=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq -r ".spec.image")
        verbose "Waiting for CAS to have spec.image=$NEXT_IMAGE spec applied in its pod - current is spec.image=$new_cas_image_in_pod"
        max_attempts=$((max_attempts - 1))
    done
    unset new_cas_image_in_pod

    new_cas_safety_service_image_in_pod=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq -r ".spec.safetyService.image")
    verbose "Waiting for CAS to have spec.safetyService.image=$CAS_SAFETY_SERVICE_UPGRADE_IMAGE spec applied in CAS safety service pods - current is $new_cas_safety_service_image_in_pod"
    max_attempts=90
    while [[ "$new_cas_safety_service_image_in_pod" != "$CAS_SAFETY_SERVICE_UPGRADE_IMAGE" ]]; do
        if [[ $max_attempts -eq 0 ]]; then
            error_exit "Failed: CAS spec.safetyService.image=$CAS_SAFETY_SERVICE_UPGRADE_IMAGE spec was not applied in CAS safety service pods in time!"
        fi
        sleep 10
        new_cas_safety_service_image_in_pod=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq -r ".spec.safetyService.image")
        verbose "Waiting for CAS to have spec.safetyService.image=$CAS_SAFETY_SERVICE_UPGRADE_IMAGE spec applied in CAS safety service pods - current is $new_cas_safety_service_image_in_pod"
        max_attempts=$((max_attempts - 1))
    done
    unset new_cas_safety_service_image_in_pod
    unset max_attempts

    verbose "Waiting CAS to be in HEALTHY state"
    STATE=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.status.state}')
    while [[ "$STATE" != "HEALTHY"  ]] ; do
        sleep 1
        STATE=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath='{.status.state}')
        verbose "Waiting for CAS to become HEALTHY again - current state is $STATE"
    done

    verbose "Sanity check that the images have changed as expected"
    backup_cas_image=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq  ".spec.\"backup-controller\".env[] | select(.name == \"BACKUP_CAS_IMAGE\").value")
    verbose "backup_cas_image in backup-controller.env[] (should be new version) $backup_cas_image"
    backup_image=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq  ".spec.\"backup-controller\".image")
    verbose "backup_image in backup-controller.image (should be new version) $backup_image"
    cas_image=$(kubectl get cas $NAME -n $NAMESPACE -o json | jq  ".spec.image")
    verbose "cas_image        (should be new version) $cas_image"

    exit 0
fi  # end of upgrading

if [[ $do_verify == 1 ]] ; then
    verbose "Verifying CAS $NAME in namespace $NAMESPACE"
    is_prov="no"
    check_if_provisioned > /dev/null && is_prov="yes"  || true
    if [[ "$is_prov" == "no" ]]; then
        error_exit "CAS '$NAME' in namespace '$NAMESPACE' is not provisioned."
    fi
    echo "CAS '$NAME' in namespace '$NAMESPACE' is attestable and provisioned."
    exit 0
fi

if [[ $do_preprovision == 1 ]]; then
     create_unprovisioned_cas "$NAME" "$NAMESPACE" "$VERSION" "$TARGET_DIR" "$CAS_PROVISIONING_URL"
     exit 0
fi

if [[ $EXISTS == 1 ]] ; then
    if [[ $do_postprovision == 1 ]] ; then
        verbose "We only perform the post-provisioning steps."
        post_provisioning
        exit 0
    fi

    if [[ $do_recovery == 1 ]]; then
        error_exit "The target CAS of a recovery must not exists. Please specify a different CAS name and namespace to use for the recovery."
    fi

    export IMAGE=$(echo $JSON | jq '(.spec.image)' | tr -d '"' | jq -R '. | sub( "(?<image>[^':']*):(?<tag>.*)" ; "\(.image)")' | tr -d '"' )
    TAG=$(echo $JSON | jq '(.spec.image)' | tr -d '"' | jq -R '. |   sub( "(?<image>[^':']*):(?<tag>.*)" ; "\(.tag)")' | tr -d '"' )
    if [[ "$IMAGE" == "null" || "$IMAGE" == "" ]] ; then
        error_exit "Cannot determine image name of CAS '$NAME' in namespace '$NAMESPACE'"
    fi

    if [[ "$IMAGE" == "$TAG" ]] ; then
        warning "CAS Image '$IMAGE' of CAS  $NAME in namespace $NAMESPACE has no tag specified!"
        export IMAGE="$IMAGE:latest"
    else
        verbose "CAS Image '$IMAGE' has tag '$TAG'"
        export IMAGE="$IMAGE:$TAG"
    fi

    if [[ "$image_overwrite" != "" ]]
    then
        warning "Using a non-standard CAS image $image_overwrite instead of $IMAGE"
        export IMAGE="$image_overwrite"
        EXPECTED_IMAGE="$image_overwrite"
    else
        EXPECTED_IMAGE="$CAS_IMAGE"
    fi
    if [[ "$IMAGE" != "$EXPECTED_IMAGE"  ]] ; then
        if [[ "$IMAGE" == "$CAS_RECOVERY_IMAGE" ]] ; then
            warning "CAS runs recovery image: $CAS_RECOVERY_IMAGE"
            export EXPECTED_IMAGE="$CAS_RECOVERY_IMAGE"
        else
            error_exit "Expected CAS Image '$EXPECTED_IMAGE' or '$CAS_RECOVERY_IMAGE' but retrieved  '$IMAGE' - exiting! I cannot change the image. Consider to change the version with ${version_flag}. Alternatively, you can set the image with option ${image_flag}."
        fi
    fi
else
    if [[ $do_postprovision == 1 ]] ; then
        error_exit "The $post_provisioning_flag flag requires the CAS to exist. No CAS $NAME found in namespace $NAMESPACE"
    fi

    IMAGE="$CAS_IMAGE"
    if [[ $do_recovery == 1 ]] ; then
        export IMAGE="$CAS_RECOVERY_IMAGE"
        EXPECTED_IMAGE="$IMAGE"
        verbose "- Recovering CAS using IMAGE $IMAGE"
    fi
    if [[ "$image_overwrite" != "" ]]
    then
        warning "Using a non-standard CAS image $image_overwrite instead of $IMAGE"
        export IMAGE="$image_overwrite"
    fi
fi


if [[ $EXISTS == 0 ]] ; then
    if [[ $do_recovery == 1 ]] ; then
        export SNAPSHOT="${SNAPSHOT:-last-snapshot-db}"
        verbose "Recovering service 'cas': NAME = '$NAME' in namespace '$NAMESPACE' using snapshot $SNAPSHOT"
        verbose "Checking permissions of snapshot files"
        need_to_fix_snapshot_permissions=0

        cas_db_owner_group="$(stat -c '%u:%g' $SNAPSHOT/cas.db)"
        cas_db_perm="$(stat -c '%a' $SNAPSHOT/cas.db)"
        if [[ "$cas_db_owner_group" == "1000:1000" ]]; then
            verbose "$SNAPSHOT/cas.db owner and group are ok: $cas_db_owner_group"
            case "$cas_db_perm" in
                66[0-7]|67[0-7]|76[0-7]|77[0-7]) # check we have at least u+g rw
                    verbose "$SNAPSHOT/cas.db owner and group permissions are ok: $cas_db_perm"
                    ;;
                *)
                    warning "$SNAPSHOT/cas.db owner and group permissions are not ok: $cas_db_perm. We will try to fix this."
                    need_to_fix_snapshot_permissions=1
                    ;;
            esac
        else
            warning "$SNAPSHOT/cas.db nonroot owner and group are not ok: $cas_db_owner_group. We will try to fix this."
            need_to_fix_snapshot_permissions=1
        fi

        cas_keystore_owner_group="$(stat -c '%u:%g' $SNAPSHOT/cas.key-store)"
        cas_keystore_perm="$(stat -c '%a' $SNAPSHOT/cas.key-store)"
        if [[ "$cas_keystore_owner_group" == "1000:1000" ]]; then
            verbose "$SNAPSHOT/cas.key-store owner and group are ok: $cas_keystore_owner_group"
            case "$cas_keystore_perm" in
                66[0-7]|67[0-7]|76[0-7]|77[0-7]) # check we have at least u+g rw
                    verbose "$SNAPSHOT/cas.key-store owner and group permissions are ok: $cas_keystore_perm"
                    ;;
                *)
                    warning "$SNAPSHOT/cas.key-store owner and group permissions are not ok: $cas_keystore_perm. We will try to fix this."
                    need_to_fix_snapshot_permissions=1
                    ;;
            esac
        else
            warning "$SNAPSHOT/cas.key-store nonroot owner and group are not ok: $cas_keystore_owner_group. We will try to fix this."
            need_to_fix_snapshot_permissions=1
        fi

        if [[ $need_to_fix_snapshot_permissions -eq 1 ]]; then
            my_user=$(whoami)
            if [[ "$my_user" == "root" ]]; then
                verbose "Detected we are running as root user, so we can fix the permissions:"
                chmod -R 660 $SNAPSHOT
                chown -R 1000:1000 $SNAPSHOT
                verbose "Done."
            else
                warning "Unable to continue with backup recovery"
                warning "Fix the permissions of the snapshot files: $SNAPSHOT/cas.db and $SNAPSHOT/cas.key-store"
                warning "Please ensure user and group [1000:1000], and read-write [ug+rw] permissions for user and group:"
                warning "chmod -R 660 $SNAPSHOT/*"
                warning "chown -R 1000:1000 $SNAPSHOT/*"
                exit 1
            fi
        fi
    fi

    verbose "CAS $NAME in namespace $NAMESPACE does not exist - creating it"

    export SVC_DNS_NAME="$NAME.$NAMESPACE.svc.cluster.local"
    if kubectl get pvc "database-$NAME-0"  --namespace "$NAMESPACE" 2> /dev/null 1> /dev/null ; then
        warning "Volume database-$NAME-0 already exists - provision of CAS for existing volume not supported: We do not want to overwrite existing database"
        exit 1
    fi

    template_file="$TARGET_DIR/owner-config/cas-$NAMESPACE-$NAME-$VERSION-provisioning-step.yaml.template"
    manifest="$TARGET_DIR/owner-config/cas-$NAMESPACE-$NAME-$VERSION-provisioning-step.yaml"

    verbose "Creating manifest '$manifest' for CAS provisioning"
    download_file "$CAS_PROVISIONING_URL" "$template_file"

    SCONE="\$SCONE" envsubst < "$template_file" > "$manifest"
    echo "  nonce: $NONCE" >> "$manifest"

    verbose "Creating/Applying CAS CR for Provisioning"
    kubectl apply -f "$manifest" 2> /dev/null 1> /dev/null || error_exit "Creation of CAS Manifest '$manifest' failed. Check that that $VERSION is supported by the SCONE operator. For imore information, execute the command 'kubectl apply -f $manifest' manually."
else
    verbose "CAS '$NAME' in namespace '$NAMESPACE' already exists - trying to provision it"
fi

POD=""
until [[ $POD != "" ]]
do
    verbose "Waiting for CAS $NAME in namespace $NAMESPACE to start"
    sleep 5
    POD=`kubectl get pod --selector "app.kubernetes.io/instance=$NAME,app.kubernetes.io/name=cas" -n "$NAMESPACE" | tail -1 | awk '{ print $1 }'` || echo "..."
done

verbose "Found POD '$POD'"

verbose "determining the CAS address"

export SVCNAME=`kubectl get svc --namespace "$NAMESPACE" --selector "app.kubernetes.io/instance=$NAME,app.kubernetes.io/name=cas" | tail -1 | awk '{ print $1 }'`
export SCONE_CAS_ADDR=$(kubectl get svc --namespace "$NAMESPACE" "$SVCNAME" --template "{{ .spec.clusterIP }}")

verbose " CAS address = $SCONE_CAS_ADDR (SVC name = $SVCNAME)"

if [[ "$SCONE_CAS_ADDR" == "" ]] ; then
    error_exit "Failed to determine IP address of service $SVCNAME in namespace $NAMESPACE"
fi

is_prov="no"
if [[ $EXISTS == 1 ]]; then
    check_if_provisioned > /dev/null && is_prov="yes"  || true
fi

if [[ "$is_prov" == "no" ]]; then
    verbose "Retrieving CAS_KEY_HASH AND CAS_PROVISIONING_TOKEN from log of pod '$POD' in namespace '$NAMESPACE'"

    RETRY=$K_PROVISION_MAX_RETRIES
    until kubectl logs $POD --namespace "$NAMESPACE" -c cas | grep "CAS key hash" > /dev/stderr
    do
        sleep 5
        verbose "Waiting for CAS key"
        RETRY=$((RETRY - 1))
        if [[ $RETRY == 0 ]] ; then
        error_exit "Cannot retrieve CAS_KEY_HASH from log of CAS $NAME. Bailing."
        fi
    done

    CAS_KEY_HASH=$(kubectl logs "$POD"  --namespace "$NAMESPACE" -c cas | grep "CAS key hash" | awk '{ print $NF } ')
    export CAS_KEY_HASH=$(echo "$CAS_KEY_HASH" | tail -1 )

    RETRY=$K_PROVISION_MAX_RETRIES
    until kubectl logs $POD --namespace "$NAMESPACE" -c cas | grep "CAS provisioning token"  > /dev/stderr
    do
        sleep 5
        verbose "Waiting for CAS provisioning token: $POD in namespace $NAMESPACE"
        RETRY=$((RETRY - 1))
        if [[ $RETRY == 0 ]] ; then
        error_exit "Cannot retrieve CAS_PROVISIONING_TOKEN from log of CAS $NAME. Bailing."
        fi
    done

    export CAS_PROVISIONING_TOKEN=$(kubectl logs "$POD"  --namespace "$NAMESPACE" -c cas | grep "CAS provisioning token" | awk ' { print $NF } ')

    if [[ "$CAS_PROVISIONING_TOKEN" == "" ]] ; then
        if [[ $EXISTS == 0 ]] ; then
            error_exit "Cannot determine the provisioning token of CAS '$NAME' in namespace '$NAMESPACE'. Bailing."
        fi
    fi
    if [[ "$CAS_KEY_HASH" == "" ]] ; then
        if [[ $EXISTS == 0 ]] ; then
            error_exit "Cannot determine the CAS_KEY of CAS '$NAME' in namespace '$NAMESPACE'. Bailing."
        fi
    fi

fi
if [[ $do_preprovision == 1 ]] ; then 
    verbose "CAS '$NAME' in namespace '$NAMESPACE' is ready. Exiting."
    echo "export CAS_KEY_HASH=$CAS_KEY_HASH"
    echo "export CAS_PROVISIONING_TOKEN=$CAS_PROVISIONING_TOKEN"
    exit 0
fi

export POLICY_NAME="cas-owner/primary-backup"

if [[ $do_recovery == 1 ]] ; then
    export SNAPSHOT="${SNAPSHOT:-last-snapshot-db}"
    verbose "Recovering service 'cas': NAME = '$NAME' in namespace '$NAMESPACE' using snapshot $SNAPSHOT"
    export OWNER_IDENTITY=$(cat "$TARGET_DIR/identity/owner_id_${SVCNAME}_$NAMESPACE.json") 
    verbose "Copying snapshot $SNAPSHOT to pod $POD"
    kubectl cp "$SNAPSHOT/cas.db" "$POD:/etc/cas/db/last-snapshot-db" -n $NAMESPACE
    kubectl cp "$SNAPSHOT/cas.key-store" "$POD:/etc/cas/db/last-snapshot-cas.key-store" -n $NAMESPACE
    # We can restart a new CAS with the same image or we roll back the CAS started in step 0:
    kubectl exec -n $NAMESPACE $POD -- sh /usr/local/bin/restart-cas 1> .restart-cas.stdout && echo "Restart initiated."  || warning "Failed to restart the cas process (Exit code: $?). Assuming its process indeed was not restarted, this script will wait in vain for the CAS to turn HEALTHY on its own. In this case, you can restart the CAS process manually by executing 'kill -HUP \$CAS_PID' inside the CAS pod, where \$CAS_PID is the process ID of the CAS process. This way the CAS might turn HEALTHY, allowing the script to continue."
    # todo: check if new CAS is up by checking the CAS_KEY and waiting until we can query the CAS keys
    verbose "Waiting for CAS to be restarted... will take 60 seconds."
    wait_for_resource_phase "cas" "$NAME" "$NAMESPACE" "HEALTHY"
    HASH=$(session_hash "provisioned" "$NAME")
    verbose "HASH is '$HASH'"
    if [ $no_port_forward == 0 ]; then
        sleep 5
        check_port_forward "$LOCAL_CAS_CLIENT_PORT"
        cas_svc_port_forward
    fi
elif [[ "$is_prov" == "yes" ]] ; then
    echo "The CAS $NAME in namespace $NAMESPACE is already provisioned. Nothing more to do."
    exit 0
else
    export SCONE_CLI_MRENCLAVE="$CURRENT_SCONE_CLI_MRENCLAVE"

    verbose "Provisioning service 'cas': NAME = '$NAME' in namespace '$NAMESPACE' using DCAP-API Key '$DCAP_KEY'"

    if [[ "$DCAP_KEY" == "$DEFAULT_DCAP_KEY" ]] ; then
        warning  "No DCAP API Key specified! Using default - this only recommended if you use a self-serving LAS (i.e., a cloud with a DCAP caching service!)"
    fi

    if [[ "$WEBHOOK" != "" ]] ; then
        SINK="network"
        WEBURL="url = \"$WEBHOOK\""
    else
        SINK="file"
        WEBURL=""
    fi

    CONFIG_FILE="$TARGET_DIR/owner-config/config.toml"
    if [[ "$OWNER_FILE" != "" ]] ; then
        verbose "Downloading owner-config from $OWNER_FILE to $CONFIG_FILE";
        download_file "$OWNER_FILE" "$CONFIG_FILE"
    else 
        cat > "$CONFIG_FILE" <<EOF
enclave_reconnect_timeout = "24h"
[api_identity]
common_name = "$SVCNAME"
alt_names = ["$POD",  "$POD.$NAMESPACE.svc.cluster.local", "$POD.$NAMESPACE",  "$SVCNAME.$NAMESPACE.svc.cluster.local", "$SVCNAME.$NAMESPACE", "localhost", "$SCONE_CAS_ADDR", "cas-instance", "host.docker.internal" ]

[audit_log]
mode = "signed"
sink = "$SINK"
$WEBURL
EOF
    fi

    if [ $no_port_forward == 1 ]; then
        cas_addr="$NAME.$NAMESPACE.svc"
    else
        sleep 5
        check_port_forward "$LOCAL_CAS_CLIENT_PORT"
        cas_svc_port_forward
        cas_addr="localhost"
    fi

    if [ $do_docker == 1 ]
    then
        touch "${TARGET_MOUNT_DIR}/identity/config.json" || error_exit "It seems you are not the owner of file '${TARGET_MOUNT_DIR}/identity/config.json' - please change owner of this file"

        docker pull ${SCONECLI_IMAGE} >/dev/null
        docker run --rm --platform linux/amd64 \
            --add-host=host.docker.internal:host-gateway --network host\
            --user $(id -u):$(id -g) \
            -v "$TARGET_MOUNT_DIR"/identity:/identity \
            -v "$TARGET_MOUNT_DIR"/owner-config:/owner-config \
            -e SCONE_CLI_CONFIG="/identity/config.json" \
            -e CAS_KEY_HASH="$CAS_KEY_HASH" \
            -e CAS_PROVISIONING_TOKEN="$CAS_PROVISIONING_TOKEN" \
            -e LOCAL_CAS_CLIENT_PORT="$LOCAL_CAS_CLIENT_PORT" \
            -e POLICY_NAME="$POLICY_NAME" \
            -e SGX_TOLERATIONS="$SGX_TOLERATIONS" \
            -e SGX_STD_TOLERATIONS="$SGX_STD_TOLERATIONS" \
            -e SCONE_NO_TIME_THREAD=1 \
            -e SCONE_PRODUCTION=0 \
            -e SCONE_MODE="sim" \
            ${SCONECLI_IMAGE} sh -c 'scone cas provision host.docker.internal:$LOCAL_CAS_CLIENT_PORT -c $CAS_KEY_HASH --token $CAS_PROVISIONING_TOKEN  --config-file /owner-config/config.toml  with-attestation  $SGX_TOLERATIONS || scone cas provision host.docker.internal:$LOCAL_CAS_CLIENT_PORT -c $CAS_KEY_HASH --token $CAS_PROVISIONING_TOKEN  --config-file /owner-config/config.toml  with-attestation  $SGX_STD_TOLERATIONS || { echo "Provisioning failed - checking if it is already provisioned!" ; scone session read provisioned 2> /dev/null ; if [ $? != 0 ] ; then  echo "Provisioning of CAS failed! FATAL ERROR: please ensure that you use a CAS that permits DB-Key injection or correct SGX_TOLERATIONS to SGX_STD_TOLERATIONS" ; exit 1 ; else  echo "CAS is already provisioned" ; fi } '

        chmod og-rwx "${TARGET_MOUNT_DIR}/identity/config.json"
    else 
        export SCONE_CLI_CONFIG="$TARGET_DIR/identity/config.json"
        export SCONE_NO_TIME_THREAD=1
        export SCONE_PRODUCTION=0
        export SCONE_MODE="sim"

        scone cas provision $cas_addr -c $CAS_KEY_HASH --token $CAS_PROVISIONING_TOKEN  --config-file "$TARGET_DIR"/owner-config/config.toml  with-attestation  $SGX_TOLERATIONS  \
        || scone cas provision $cas_addr -c $CAS_KEY_HASH --token $CAS_PROVISIONING_TOKEN  --config-file "$TARGET_DIR"/owner-config/config.toml  with-attestation  $SGX_STD_TOLERATIONS  \
        || { echo "Provisioning failed - checking if it is already provisioned!" ; scone session read provisioned 2> /dev/null ; if [ $? != 0 ] ; then  echo "Provisioning of CAS failed! FATAL ERROR: please ensure that you use a CAS that permits DB-Key injection or correct SGX_TOLERATIONS to SGX_STD_TOLERATIONS" ; exit 1 ; else  echo "CAS is already provisioned" ; fi }
    fi

    upload_post_provisioning_sessions
fi

enable_post_provisioning_features

# In case we did recovery, we must put the normal CAS image back
if [[ $do_recovery == 1 ]] ; then
    verbose "Checking current .spec.image"
    actual_cas_image=$(kubectl get cas $NAME -n $NAMESPACE -o jsonpath={.spec.image})
    if [[ "$actual_cas_image" == *"/cas-recovery:$VERSION" ]]; then
        verbose "Replacing CAS Recovery image by the normal CAS image on .spec.image: $actual_cas_image -> $CAS_IMAGE"
        kubectl patch cas $NAME -n $NAMESPACE --type json --patch """
            [
                {
                    "op": "replace",
                    "path": "/spec/image",
                    "value": "$CAS_IMAGE"
